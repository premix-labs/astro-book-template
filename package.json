{
  "name": "astro-book-template",
  "type": "module",
  "version": "1.0.0",
  "description": "Reusable Astro + Tailwind 4 template for technical books, rebrandable per book via src/site.config.ts",
  "engines": {
    "node": "^22.22.3 || ^24.16.0 || >=26.3.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build && pagefind --site dist",
    "preview": "astro preview",
    "astro": "astro",
    "check": "astro check",
    "check:book": "node scripts/validate-book.mjs",
    "check:links": "node scripts/check-links.mjs",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "new-chapter": "node scripts/new-chapter.mjs",
    "create-book": "node scripts/create-book.mjs",
    "template:status": "node scripts/sync-template.mjs --status",
    "template:check": "node scripts/sync-template.mjs --check",
    "template:update": "node scripts/sync-template.mjs --apply",
    "test": "node --test scripts/tests/*.test.mjs",
    "test:e2e": "playwright test tests/e2e",
    "test:e2e:chromium": "playwright test tests/e2e --project=chromium-desktop --project=chromium-tablet --project=chromium-mobile",
    "test:visual": "playwright test tests/visual --project=chromium-desktop --project=chromium-mobile",
    "test:visual:update": "npm run test:visual -- --update-snapshots",
    "test:performance": "playwright test tests/performance --project=chromium-desktop",
    "security:audit": "npm audit --audit-level=moderate",
    "verify": "npm run format:check && npm run lint && npm run check && npm run test && npm run check:book && npm run build && npm run check:links",
    "verify:enterprise": "npm run verify && npm run test:e2e:chromium && npm run test:visual && npm run test:performance && npm run security:audit"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/mdx": "^7.0.2",
    "@fontsource-variable/noto-sans-thai": "^5.2.8",
    "@fontsource-variable/noto-serif-thai": "^5.2.7",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@lucide/astro": "^1.24.0",
    "@tailwindcss/typography": "^0.5.20",
    "astro": "^7.0.7",
    "mermaid": "^11.16.0",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^24.0.0",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "eslint": "^10.7.0",
    "eslint-plugin-astro": "^2.1.1",
    "pagefind": "^1.5.2",
    "parse5": "^8.0.1",
    "prettier": "^3.9.5",
    "prettier-plugin-astro": "^0.14.1",
    "tailwindcss": "^4.3.2"
  }
}

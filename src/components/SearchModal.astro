---
import { Search, X } from '@lucide/astro';
import { withBase } from '../utils/url';

const isProd = import.meta.env.PROD;
---

{
  isProd ? (
    <>
      <pagefind-config bundle-path={withBase('pagefind/')} base-url={withBase('')} instance="book-search" />
      <pagefind-modal instance="book-search" reset-on-close />
      <link href={withBase('pagefind/pagefind-component-ui.css')} rel="stylesheet" />
      <script is:inline type="module" src={withBase('pagefind/pagefind-component-ui.js')} />
    </>
  ) : (
    <dialog
      id="book-search-modal"
      class="w-[min(36rem,calc(100%-2rem))] rounded-md border border-line-def bg-surface-card p-0 text-content-main shadow-[var(--shadow-modal)] backdrop:bg-black/50"
      aria-labelledby="search-development-title"
    >
      <div class="flex items-start gap-4 p-6">
        <Search class="mt-1 h-5 w-5 shrink-0 text-primary-400" aria-hidden="true" />
        <div class="min-w-0 flex-1">
          <h2 id="search-development-title" class="text-lg font-semibold">
            Search requires a production build
          </h2>
          <p class="mt-2 text-sm leading-6 text-content-mut">
            Run <code class="rounded bg-surface-elev px-1.5 py-0.5 font-code">npm run build</code>, then{' '}
            <code class="rounded bg-surface-elev px-1.5 py-0.5 font-code">npm run preview</code>.
          </p>
        </div>
        <form method="dialog">
          <button
            class="flex h-8 w-8 items-center justify-center rounded-md text-content-mut hover:bg-surface-elev hover:text-content-main"
            aria-label="Close search information"
          >
            <X class="h-4 w-4" />
          </button>
        </form>
      </div>
    </dialog>
  )
}

<style is:global>
  pagefind-modal {
    --pf-text: var(--text-primary);
    --pf-text-secondary: var(--text-secondary);
    --pf-text-muted: var(--text-muted);
    --pf-background: var(--bg-card);
    --pf-border: var(--border-default);
    --pf-border-focus: var(--border-strong);
    --pf-skeleton: var(--bg-elevated);
    --pf-skeleton-shine: var(--bg-hover);
    --pf-hover: var(--bg-hover);
    --pf-mark: var(--primary-400);
    --pf-outline-focus: var(--primary-400);
    --pf-font: var(--font-sans);
    --pf-border-radius: var(--radius-md);
    --pf-modal-max-width: 680px;
  }
</style>

<script>
  let searchKeydownHandler: ((event: KeyboardEvent) => void) | null = null;

  function openSearch() {
    const modal = document.querySelector('pagefind-modal') ?? document.getElementById('book-search-modal');
    if (modal instanceof HTMLDialogElement) {
      if (!modal.open) modal.showModal();
      return;
    }

    const pagefindModal = modal as (HTMLElement & { open?: () => void }) | null;
    pagefindModal?.open?.();
  }

  document.addEventListener('astro:page-load', () => {
    document.querySelectorAll<HTMLElement>('.open-search-btn').forEach((button) => {
      if (button.dataset.searchBound === 'true') return;
      button.dataset.searchBound = 'true';
      button.addEventListener('click', openSearch);
    });

    if (searchKeydownHandler) window.removeEventListener('keydown', searchKeydownHandler);
    searchKeydownHandler = (event: KeyboardEvent) => {
      if ((event.ctrlKey || event.metaKey) && event.key.toLowerCase() === 'k') {
        event.preventDefault();
        openSearch();
      }
    };
    window.addEventListener('keydown', searchKeydownHandler);
  });
</script>

---
// SearchModal.astro
const isProd = import.meta.env.PROD;
---

<div id="search-modal" class="search-modal glass-panel" aria-hidden="true">
  <div class="search-modal-backdrop" id="search-modal-close-area"></div>
  <div class="search-modal-content">
    <div id="search-ui">
      {
        !isProd && (
          <div class="p-8 text-center text-content-mut">
            <div class="text-[2rem] mb-4">🔍</div>
            <p>Search is disabled in Development mode.</p>
            <p class="text-[0.85rem] mt-2">
              Run <code class="bg-surface-elev px-1.5 py-0.5 rounded font-code">npm run build</code> and{' '}
              <code class="bg-surface-elev px-1.5 py-0.5 rounded font-code">npm run preview</code> to test search.
            </p>
          </div>
        )
      }
    </div>
    <div class="search-modal-footer">
      <span><kbd>Esc</kbd> to close</span>
    </div>
  </div>
</div>

<style is:global>
  .search-modal {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 9999;
    display: flex;
    justify-content: center;
    align-items: flex-start;
    padding-top: 10vh;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }
  .search-modal.active {
    opacity: 1;
    pointer-events: auto;
  }
  .search-modal-backdrop {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.6);
    z-index: -1;
  }
  .search-modal-content {
    width: 100%;
    max-width: 600px;
    background: var(--bg-card);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-lg);
  }
  .search-modal-footer {
    padding: 12px 20px;
    font-size: 0.75rem;
    color: var(--text-muted);
    border-top: 1px solid var(--border-subtle);
    display: flex;
    justify-content: flex-end;
  }
  .search-modal-footer kbd {
    background: var(--bg-elevated);
    border: 1px solid var(--border-subtle);
    border-radius: 4px;
    padding: 2px 6px;
    margin-right: 4px;
    font-family: var(--font-code);
  }

  /* Override Pagefind Default Styles for Dark Mode */
  .pagefind-ui {
    --pagefind-ui-scale: 0.9;
    --pagefind-ui-primary: var(--primary-400);
    --pagefind-ui-text: var(--text-primary);
    --pagefind-ui-background: var(--bg-card);
    --pagefind-ui-border: var(--border-default);
    --pagefind-ui-tag: var(--bg-elevated);
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: var(--radius-md);
    --pagefind-ui-image-border-radius: var(--radius-sm);
    --pagefind-ui-font: var(--font-sans);
  }
</style>

{
  isProd && (
    <>
      <link href="/pagefind/pagefind-ui.css" rel="stylesheet" />
      <script is:inline src="/pagefind/pagefind-ui.js" />
    </>
  )
}

<script>
  let searchKeydownHandler: ((e: KeyboardEvent) => void) | null = null;

  document.addEventListener('astro:page-load', () => {
    const searchUiContainer = document.getElementById('search-ui');
    if (searchUiContainer && searchUiContainer.innerHTML === '') {
      try {
        // @ts-ignore
        new PagefindUI({ element: '#search-ui', showSubResults: true, showImages: false });
      } catch (e) {
        console.warn('Pagefind UI not loaded. Run build first.');
      }
    }

    const modal = document.getElementById('search-modal');
    const closeArea = document.getElementById('search-modal-close-area');

    const openSearch = () => {
      modal?.classList.add('active');
      const input = document.querySelector('.pagefind-ui__search-input') as HTMLInputElement | null;
      if (input) setTimeout(() => input.focus(), 100);
    };

    const closeSearch = () => {
      modal?.classList.remove('active');
    };

    if (searchKeydownHandler) {
      window.removeEventListener('keydown', searchKeydownHandler);
    }

    searchKeydownHandler = (e: KeyboardEvent) => {
      if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
        e.preventDefault();
        openSearch();
      }
      if (e.key === 'Escape') {
        closeSearch();
      }
    };

    window.addEventListener('keydown', searchKeydownHandler);

    closeArea?.addEventListener('click', closeSearch);

    const searchBtns = document.querySelectorAll('.open-search-btn');
    searchBtns.forEach((btn) => btn.addEventListener('click', openSearch));
  });
</script>

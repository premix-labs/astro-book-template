---
interface ChapterLink {
  num: number;
  title: string;
  href: string;
  part?: string;
}

interface Props {
  chapters: ChapterLink[];
  currentPath: string;
}

const { chapters, currentPath } = Astro.props;
const hasParts = chapters.some((chapter) => chapter.part);

interface Group {
  label: string | null;
  items: ChapterLink[];
}

const groups: Group[] = [];
for (const chapter of chapters) {
  const label = chapter.part ?? null;
  const last = groups.at(-1);
  if (last?.label === label) last.items.push(chapter);
  else groups.push({ label, items: [chapter] });
}
---

<nav class="chapter-navigation" aria-label="Chapters">
  {!hasParts && <div class="chapter-navigation-label">Contents</div>}
  {
    groups.map((group) => (
      <section class="chapter-navigation-group" aria-label={group.label ?? 'Chapters'}>
        {group.label && <div class="chapter-navigation-label">{group.label}</div>}
        {group.items.map((chapter) => {
          const isActive = currentPath === chapter.href || currentPath === `${chapter.href}/`;
          return (
            <a
              href={chapter.href}
              class:list={['chapter-navigation-link', { 'is-active': isActive }]}
              aria-current={isActive ? 'page' : undefined}
            >
              <span class="chapter-navigation-number" aria-hidden="true">
                {String(chapter.num).padStart(2, '0')}
              </span>
              <span>{chapter.title}</span>
            </a>
          );
        })}
      </section>
    ))
  }
</nav>

<style>
  .chapter-navigation {
    display: grid;
    gap: 16px;
    padding-bottom: 24px;
  }

  .chapter-navigation-group {
    display: grid;
    gap: 2px;
  }

  .chapter-navigation-label {
    padding: 0 20px 7px;
    color: var(--text-muted);
    font-size: 0.68rem;
    font-weight: 750;
    text-transform: uppercase;
  }

  .chapter-navigation-link {
    position: relative;
    display: grid;
    grid-template-columns: 28px minmax(0, 1fr);
    align-items: center;
    gap: 10px;
    min-height: 42px;
    padding: 7px 18px 7px 20px;
    color: var(--text-secondary);
    font-size: 0.82rem;
    line-height: 1.35;
    text-decoration: none;
    transition:
      background-color 130ms var(--ease-standard),
      color 130ms var(--ease-standard);
  }

  .chapter-navigation-link:hover {
    background: var(--bg-elevated);
    color: var(--text-primary);
  }

  .chapter-navigation-link.is-active {
    background: var(--bg-hover);
    color: var(--text-accent);
    font-weight: 700;
  }

  .chapter-navigation-link.is-active::before {
    content: '';
    position: absolute;
    inset: 7px auto 7px 0;
    width: 3px;
    background: var(--teal-600);
  }

  .chapter-navigation-number {
    color: var(--text-muted);
    font-family: var(--book-font-code);
    font-size: 0.67rem;
    font-weight: 600;
  }

  .chapter-navigation-link.is-active .chapter-navigation-number {
    color: var(--text-accent);
  }
</style>

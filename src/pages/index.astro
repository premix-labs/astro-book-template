---
import '@fontsource/inter/latin.css';
import '@fontsource-variable/noto-sans-thai/index.css';
import '@fontsource-variable/noto-serif-thai/index.css';
import '@fontsource/jetbrains-mono/latin.css';
import '../styles/global.css';
import { getCollection } from 'astro:content';
import { ClientRouter } from 'astro:transitions';
import EnterpriseHeader from '../components/EnterpriseHeader.astro';
import SearchModal from '../components/SearchModal.astro';
import ThemeHead from '../components/ThemeHead.astro';
import { siteConfig } from '../site.config';
import { calculateReadingTime } from '../utils/readingTime';
import { absoluteUrl, absoluteUrlFromFullPath, withBase } from '../utils/url';
import { ArrowRight, Blocks, BookOpen, CircleCheckBig, Clock3, House, Languages, Route } from '@lucide/astro';

const allChapters = await getCollection('chapters', ({ data }) => !data.draft);
const chapters = allChapters
  .sort((a, b) => a.data.chapter - b.data.chapter)
  .map((entry) => ({
    num: String(entry.data.chapter).padStart(2, '0'),
    href: withBase(entry.id),
    title: entry.data.title,
    description: entry.data.description,
    part: entry.data.part,
    readingTime: entry.data.readingTime ?? `${calculateReadingTime(entry.body ?? '')} min`,
  }));

interface ChapterGroup {
  label: string | null;
  items: typeof chapters;
}

const chapterGroups: ChapterGroup[] = [];
for (const chapter of chapters) {
  const label = chapter.part ?? null;
  const last = chapterGroups.at(-1);
  if (last?.label === label) last.items.push(chapter);
  else chapterGroups.push({ label, items: [chapter] });
}

const firstChapter = chapters[0];
const lastChapter = chapters.at(-1);
const languageName = siteConfig.lang.toLowerCase().startsWith('th') ? 'Thai' : 'English';
const canonicalUrl = absoluteUrlFromFullPath(Astro.url.pathname, Astro.site);
const ogImageUrl = siteConfig.ogImage ? absoluteUrl(siteConfig.ogImage, Astro.site) : '';
---

<!doctype html>
<html lang={siteConfig.lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={siteConfig.description} />
    <title>{siteConfig.title}</title>
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:title" content={siteConfig.title} />
    <meta property="og:description" content={siteConfig.description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    {
      ogImageUrl && (
        <>
          <meta property="og:image" content={ogImageUrl} />
          <meta name="twitter:card" content="summary_large_image" />
          <meta name="twitter:image" content={ogImageUrl} />
        </>
      )
    }
    <ThemeHead />
    <link rel="icon" type="image/svg+xml" href={withBase('favicon.svg')} />
    <ClientRouter />
  </head>
  <body>
    <a href="#learning-path" class="skip-link">Skip to learning path</a>

    <EnterpriseHeader />

    <div class="home-shell">
      <aside class="home-sidebar" aria-label="Book sections">
        <nav>
          <a href={withBase('')} class="home-nav-link is-active" aria-current="page">
            <House class="size-4" />
            <span>Home</span>
          </a>
          <a href="#learning-path" class="home-nav-link">
            <Route class="size-4" />
            <span>Learning path</span>
          </a>
          {
            lastChapter && (
              <a href={lastChapter.href} class="home-nav-link">
                <Blocks class="size-4" />
                <span>Authoring components</span>
              </a>
            )
          }
        </nav>
      </aside>

      <main class="home-main">
        <section class="home-introduction" aria-labelledby="book-title">
          <div class="section-label"><BookOpen class="size-4" /> Technical book</div>
          <h1 id="book-title">{siteConfig.title}</h1>
          <p>{siteConfig.description}</p>
          {
            firstChapter && (
              <a href={firstChapter.href} class="primary-command">
                <span>Continue with {firstChapter.title}</span>
                <ArrowRight class="size-4" />
              </a>
            )
          }
        </section>

        <section class="learning-section" id="learning-path" aria-labelledby="learning-path-title">
          <div class="section-heading">
            <div>
              <span class="section-label">Curriculum</span>
              <h2 id="learning-path-title">Learning path</h2>
            </div>
            <span class="chapter-count">{chapters.length} chapters</span>
          </div>

          <div class="chapter-list">
            {
              chapterGroups.map((group) => (
                <section class="chapter-group" aria-label={group.label ?? 'Chapters'}>
                  {group.label && <h3 class="part-heading">{group.label}</h3>}
                  {group.items.map((chapter) => (
                    <a href={chapter.href} class="chapter-row">
                      <span class="chapter-number" aria-hidden="true">
                        {chapter.num}
                      </span>
                      <span class="chapter-copy">
                        <strong>{chapter.title}</strong>
                        {chapter.description && <span>{chapter.description}</span>}
                      </span>
                      <span class="chapter-time">
                        <Clock3 class="size-3.5" /> {chapter.readingTime}
                      </span>
                      <ArrowRight class="chapter-arrow size-4" aria-hidden="true" />
                    </a>
                  ))}
                </section>
              ))
            }
          </div>
        </section>
      </main>

      <aside class="book-info" aria-labelledby="book-info-title">
        <h2 id="book-info-title">Book information</h2>
        <dl>
          <div>
            <dt><BookOpen class="size-4" /> Chapters</dt>
            <dd>{chapters.length}</dd>
          </div>
          <div>
            <dt><Languages class="size-4" /> Language</dt>
            <dd>{languageName}</dd>
          </div>
          <div>
            <dt><CircleCheckBig class="size-4" /> Status</dt>
            <dd class="status-value">{siteConfig.statusLabel}</dd>
          </div>
        </dl>
        {siteConfig.lastReviewed && <p class="reviewed-date">Reviewed {siteConfig.lastReviewed}</p>}
      </aside>
    </div>

    <footer class="enterprise-footer">
      <span>{siteConfig.footer.text}</span>
      <span>Built for focused technical reading</span>
    </footer>

    <SearchModal />
  </body>
</html>
